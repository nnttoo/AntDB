/// Encodes a `Resp` value into its RESP binary buffer representation.
pub fn serialize_resp(value: &Resp) -> Vec<u8> {
    let mut buf = Vec::new();
    buf_serialize(value, &mut buf);
    buf
}

/// Helper function to recursively serialize `Resp` variants into a shared buffer.
fn buf_serialize(value: &Resp, buf: &mut Vec<u8>) {
    const CRLF: &[u8] = b"\r\n";

    match value {
        Resp::SimpleString(s) => {
            buf.push(b'+');
            buf.extend_from_slice(s.as_bytes());
            buf.extend_from_slice(CRLF);
        }
        Resp::Error(e) => {
            buf.push(b'-');
            buf.extend_from_slice(e.as_bytes());
            buf.extend_from_slice(CRLF);
        }
        Resp::Integer(n) => {
            buf.push(b':');
            buf.extend_from_slice(n.to_string().as_bytes());
            buf.extend_from_slice(CRLF);
        }
        Resp::BulkString(opt_bytes) => {
            buf.push(b'$');
            match opt_bytes {
                Some(bytes) => {
                    buf.extend_from_slice(bytes.len().to_string().as_bytes());
                    buf.extend_from_slice(CRLF);
                    buf.extend_from_slice(bytes);
                    buf.extend_from_slice(CRLF);
                }
                None => {
                    buf.extend_from_slice(b"-1");
                    buf.extend_from_slice(CRLF);
                }
            }
        }
        Resp::Array(opt_elements) => {
            buf.push(b'*');
            match opt_elements {
                Some(elements) => {
                    buf.extend_from_slice(elements.len().to_string().as_bytes());
                    buf.extend_from_slice(CRLF);
                    for item in elements {
                        buf_serialize(item, buf);
                    }
                }
                None => {
                    buf.extend_from_slice(b"-1");
                    buf.extend_from_slice(CRLF);
                }
            }
        }
    }
}