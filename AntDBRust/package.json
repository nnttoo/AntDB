{
  "name": "antdbrust",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "cargo build --release",
    "build_linux": "cargo zigbuild --release --target x86_64-unknown-linux-musl",
    "node_test" : "cd ../nodeTester/ && npm run node_test",
    "cargo_run" : "concurrently -n  AntDb,Test \"cargo run\"",
    "sleep" : "node -e \"setTimeout(() => {}, 4000)\"",
    "run" : "npm run cargo_run -- \"npm run sleep && npm run node_test \"",
    "benchmark" : "cd ../redisBenchMark/ && npm run run_all",
    "benchmark_only" : "cd ../redisBenchMark/ && npm run run_bmark",
    "benchmark_400mb" : "npm run cargo_run -- \"npm run sleep && cd ../nodeTester/ && npm run node_bigsize -- 400mb \""
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "concurrently": "^10.0.3"
  }
}
